{
  "name": "@soroban-scanner/ui-components",
  "version": "1.0.0",
  "description": "Reusable UI components and utilities for Soroban Security Scanner",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/component-library/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && tsc --project tsconfig.build.json",
    "dev": "rollup -c -w",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "typescript",
    "components",
    "ui",
    "soroban"
  ],
  "author": "connect-boiz",
  "license": "MIT",
  "dependencies": {
    "date-fns": "^2.30.0",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "i18next": "^23.7.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^30.4.1",
    "rollup": "^3.26.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/frankosakwe/soroban-security-scanner.git",
    "directory": "component-library"
  },
  "bugs": {
    "url": "https://github.com/frankosakwe/soroban-security-scanner/issues"
  },
  "homepage": "https://github.com/frankosakwe/soroban-security-scanner#readme"
