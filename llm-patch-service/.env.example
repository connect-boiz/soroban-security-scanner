# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# Alternative LLM Providers
# For Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-sonnet-20240229

# For Ollama (Local)
# LLM_PROVIDER=ollama
# LLM_API_KEY=http://localhost:11434
# LLM_MODEL=llama2

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/llm_patch_service
DB_MAX_CONNECTIONS=10

# Logging Configuration
RUST_LOG=llm_patch_service=debug,tower_http=debug

# Security Configuration
# Enable additional security features
ENABLE_SANITIZATION=true
ENABLE_VERIFICATION=true
MIN_CONFIDENCE_THRESHOLD=0.4

# Performance Configuration
# Maximum number of concurrent patch requests
MAX_CONCURRENT_REQUESTS=10

# Timeout Configuration
# LLM request timeout in seconds
LLM_TIMEOUT=60

# Compilation verification timeout in seconds
VERIFICATION_TIMEOUT=30
