{
  "name": "@soroban-scanner/frontend",
  "version": "1.0.0",
  "description": "Frontend application for Soroban Security Scanner",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "bundle-analyzer": "npx @next/bundle-analyzer",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "performance-test": "npm run build && npm run lighthouse",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testPathPattern=security-headers"
  },
  "dependencies": {
    "@soroban-scanner/ui-components": "file:../component-library",
    "@stellar/freighter-api": "^1.6.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "@types/crypto-js": "^4.2.1",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^1.13.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-joyride": "^3.1.0",
    "recharts": "^3.8.1",
    "swr": "^2.2.4",
    "tailwindcss": "^3.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-joyride": "^2.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.45.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lighthouse": "^11.0.0",
    "postcss": "^8.4.32",
    "ts-jest": "^29.4.9",
    "typescript": "^5.1.0",
    "webpack-bundle-analyzer": "^4.9.0"
  }
}
