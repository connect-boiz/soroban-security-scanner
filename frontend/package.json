{
  "name": "@soroban-scanner/frontend",
  "version": "1.0.0",
  "description": "Frontend application for Soroban Security Scanner",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "bundle-analyzer": "npx @next/bundle-analyzer",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "performance-test": "npm run build && npm run lighthouse"
  },
  "dependencies": {
    "@stellar/freighter-api": "^1.6.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "@types/crypto-js": "^4.2.1",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "next": "14.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.8.1",
    "swr": "^2.2.4",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "postcss": "^8",
    "typescript": "^5"
  }
}
